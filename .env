NODE_ENV=production
PORT=3001

# Connection params for the Bitcoin Node via RPC
BITCOIND_HOST=$BITCOIND_HOST
BITCOIND_PORT=$BITCOIND_PORT
BITCOIND_RPC_USER=$BITCOIND_RPC_USER
BITCOIND_RPC_PASS=$BITCOIND_RPC_PASS

# Thresholds for the different fee levels (Low, medium, and all others as high). Value specified in sats (sats/vByte).
LOW_FEE_THRESHOLD=10
MEDIUM_FEE_THRESHOLD=50

# Time interval between updates of Bitcoin fees with the Bitcoin node. Value specified in milliseconds.
UPDATE_FEE_INTERVAL=600000
